{
  "manifest_version": 3,
  "name": "LETUS Auto Login",
  "version": "1.0",
  "description": "東京理科大学 LETUS に自動ログインする拡張機能",
  "permissions": [
    "storage",
    "tabs",
    "cookies",
    "alarms"
  ],
  "host_permissions": [
    "https://letus.ed.tus.ac.jp/*",
    "https://idp.admin.tus.ac.jp/*",
    "https://login.microsoftonline.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LETUS Auto Login"
  }
}
